{
  "name": "routelm",
  "version": "1.0.0",
  "private": true,
  "description": "Root convenience scripts — start the FastAPI backend and the Vite frontend dev server together.",
  "scripts": {
    "dev": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"cyan,magenta\" --kill-others-on-fail \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": ".\\venv\\Scripts\\python -m uvicorn backend.main:app --port 8000 --reload",
    "dev:frontend": "npm --prefix frontend run dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
