# Copy this file to .env and fill in your own values.

# "groq" (cloud, fast) or "ollama" (local). Default: ollama.
LLM_PROVIDER=groq

# Required if LLM_PROVIDER=groq. Get one at https://console.groq.com/keys
GROQ_API_KEY=

# Override the Groq model if you want; default is fine for most uses.
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# Long random string. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# If unset, a random one is generated at startup and sessions die on restart.
JWT_SECRET=

# Optional Ollama overrides (only if not running on localhost:11434)
# OLLAMA_URL=http://localhost:11434
# EMBED_MODEL=bge-m3
# OLLAMA_LLM_MODEL=llama3.2

# Per-course thresholds live in data/courses.json (each course overrides
# these). The values below are only used as fallbacks when a course entry
# is missing one of them.
# COURSE_THRESHOLD=0.58
# GENERAL_THRESHOLD=0.50

# Set to "false" in tests / local dev if rate limits are getting in the way.
# RATE_LIMIT_ENABLED=true

# CORS origins for the FastAPI app (comma-separated)
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Optional: LangSmith tracing ---
# Get a key at https://smith.langchain.com/. With these two set, every chain call
# (classify, retrieve, generate) gets traced — useful for debugging routing
# decisions or measuring latency per node.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=routelm

# --- Optional: demo deployment ---
# Set both to auto-create a 'demo' login on a public deployment.
# SEED_DEMO_USER=true
# DEMO_USER_PASSWORD=
